# =============================================================
# GHAMKHETI GURU COMPANY LIMITED — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── Application ───────────────────────────────────────────────
# Public URL used for Open Graph, sitemaps, and canonical URLs.
# No trailing slash. Must match your Vercel deployment URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Ghamkheti Guru Company Limited"
NEXT_PUBLIC_APP_DESCRIPTION="Nepal's leading integrated energy and agriculture group"

# ── MongoDB Atlas ─────────────────────────────────────────────
# Full connection string — include retryWrites=true&w=majority for auto-retry.
# Create a dedicated database user with read/write on the target database only.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=GhamkhetiGuru
# Database name — no spaces, lowercase, hyphens OK
MONGODB_DB_NAME=ghamkheti-guru
# Connection pool — keep low (2–5) on Vercel serverless, raise on dedicated server
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_POOL_SIZE=10

# ── NextAuth v5 ───────────────────────────────────────────────
# Must match your deployment URL exactly (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Minimum 32 characters random string.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Session JWT max age in seconds (default: 2592000 = 30 days)
# AUTH_SESSION_MAX_AGE=2592000

# ── First-time Setup ──────────────────────────────────────────
# Set to "true" ONLY when creating the first super admin via /api/auth/seed.
# Remove or set to "false" immediately after seeding. Never leave as "true" in production.
ALLOW_SEED=false

# ── Email / SMTP ──────────────────────────────────────────────
# Used for contact-form notification emails and transactional messages.
# Gmail example: use an App Password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ghamkhetiguru@gmail.com
SMTP_PASSWORD=
# Recipient address for contact-form submissions
CONTACT_NOTIFY_EMAIL=ghamkhetiguru@gmail.com

# ── Analytics (optional) ──────────────────────────────────────
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
